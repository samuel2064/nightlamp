# Nightlamp Backend — Environment Configuration
# Copy to .env and fill in values for local development.

# Server
PORT=3000
NODE_ENV=development

# Database path (Docker: /data/nightlamp.db; local: nightlamp.db)
DATABASE_PATH=nightlamp.db

# Stripe (test mode keys from https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# Sentry DSN (from https://sentry.io/settings/projects/<project>/keys/)
SENTRY_DSN=https://xxxxxxxxxxxx@xxxxxxxxxxxx.ingest.us.sentry.io/1234567

# UptimeRobot (from https://uptimerobot.com/api/)
UPTIMEROBOT_API_KEY=u123456-xxxxxxxxxxxx
UPTIMEROBOT_MAIN_MONITOR_ID=7890123
